{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.ai-cad/schemas/raspberry_pi4_case.parameters.schema.json",
  "title": "Raspberry Pi 4 enclosure parameters",
  "description": "Validation and parameter-editor metadata for the AI CAD project.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pcb_length",
    "pcb_width",
    "pcb_thickness",
    "pcb_corner_radius",
    "mount_pitch_x",
    "mount_pitch_y",
    "mount_edge_offset",
    "mount_hole_diameter",
    "pcb_clearance",
    "wall_thickness",
    "floor_thickness",
    "base_height",
    "outer_corner_radius",
    "standoff_diameter",
    "standoff_height",
    "screw_clearance_diameter",
    "lid_top_thickness",
    "lid_skirt_depth",
    "lid_skirt_thickness",
    "lid_fit_clearance",
    "usb_c_center_x",
    "usb_c_opening_width",
    "micro_hdmi_0_center_x",
    "micro_hdmi_1_center_x",
    "micro_hdmi_opening_width",
    "audio_center_x",
    "audio_opening_width",
    "usb_2_center_y",
    "usb_3_center_y",
    "usb_opening_width",
    "ethernet_center_y",
    "ethernet_opening_width",
    "microsd_center_y",
    "microsd_opening_width",
    "gpio_slot_center_x",
    "gpio_slot_center_y",
    "gpio_slot_length",
    "gpio_slot_width",
    "fan_center_x",
    "fan_center_y",
    "fan_hole_pitch",
    "fan_screw_diameter"
  ],
  "properties": {
    "pcb_length": {"$ref": "#/$defs/locked_dimension", "title": "PCB length", "minimum": 84.5, "maximum": 85.5, "x-ui": {"group": "Reference PCB", "order": 10}},
    "pcb_width": {"$ref": "#/$defs/locked_dimension", "title": "PCB width", "minimum": 55.5, "maximum": 56.5, "x-ui": {"group": "Reference PCB", "order": 20}},
    "pcb_thickness": {"$ref": "#/$defs/locked_dimension", "title": "Nominal PCB thickness", "minimum": 1.4, "maximum": 2.0, "x-ui": {"group": "Reference PCB", "order": 30}},
    "pcb_corner_radius": {"$ref": "#/$defs/locked_dimension", "title": "PCB corner radius", "minimum": 2.5, "maximum": 3.5, "x-ui": {"group": "Reference PCB", "order": 40}},
    "mount_pitch_x": {"$ref": "#/$defs/locked_dimension", "title": "Mounting pitch X", "minimum": 57.5, "maximum": 58.5, "x-ui": {"group": "Reference PCB", "order": 50}},
    "mount_pitch_y": {"$ref": "#/$defs/locked_dimension", "title": "Mounting pitch Y", "minimum": 48.5, "maximum": 49.5, "x-ui": {"group": "Reference PCB", "order": 60}},
    "mount_edge_offset": {"$ref": "#/$defs/locked_dimension", "title": "Mounting edge offset", "minimum": 3.0, "maximum": 4.0, "x-ui": {"group": "Reference PCB", "order": 70}},
    "mount_hole_diameter": {"$ref": "#/$defs/locked_dimension", "title": "PCB mounting hole diameter", "minimum": 2.5, "maximum": 3.0, "x-ui": {"group": "Reference PCB", "order": 80}},

    "pcb_clearance": {"$ref": "#/$defs/editable_dimension", "title": "PCB edge clearance", "minimum": 0.5, "maximum": 4.0, "x-step": 0.05, "x-ui": {"group": "Base", "order": 100, "control": "number"}},
    "wall_thickness": {"$ref": "#/$defs/editable_dimension", "title": "Wall thickness", "minimum": 1.2, "maximum": 5.0, "x-step": 0.1, "x-ui": {"group": "Base", "order": 110, "control": "slider"}},
    "floor_thickness": {"$ref": "#/$defs/editable_dimension", "title": "Floor thickness", "minimum": 1.2, "maximum": 5.0, "x-step": 0.1, "x-ui": {"group": "Base", "order": 120, "control": "slider"}},
    "base_height": {"$ref": "#/$defs/editable_dimension", "title": "Base height", "minimum": 18.0, "maximum": 45.0, "x-step": 0.1, "x-ui": {"group": "Base", "order": 130, "control": "slider"}},
    "outer_corner_radius": {"$ref": "#/$defs/editable_dimension", "title": "Outer corner radius", "minimum": 1.0, "maximum": 10.0, "x-step": 0.1, "x-ui": {"group": "Base", "order": 140, "control": "slider"}},
    "standoff_diameter": {"$ref": "#/$defs/editable_dimension", "title": "Standoff diameter", "minimum": 4.5, "maximum": 10.0, "x-step": 0.1, "x-ui": {"group": "Mounting", "order": 150, "control": "number"}},
    "standoff_height": {"$ref": "#/$defs/editable_dimension", "title": "Standoff height", "minimum": 2.0, "maximum": 10.0, "x-step": 0.1, "x-ui": {"group": "Mounting", "order": 160, "control": "number"}},
    "screw_clearance_diameter": {"$ref": "#/$defs/editable_dimension", "title": "Screw clearance diameter", "minimum": 2.6, "maximum": 4.0, "x-step": 0.05, "x-ui": {"group": "Mounting", "order": 170, "control": "number"}},

    "lid_top_thickness": {"$ref": "#/$defs/editable_dimension", "title": "Lid top thickness", "minimum": 1.2, "maximum": 5.0, "x-step": 0.1, "x-ui": {"group": "Lid", "order": 200, "control": "slider"}},
    "lid_skirt_depth": {"$ref": "#/$defs/editable_dimension", "title": "Lid skirt depth", "minimum": 1.5, "maximum": 8.0, "x-step": 0.1, "x-ui": {"group": "Lid", "order": 210, "control": "slider"}},
    "lid_skirt_thickness": {"$ref": "#/$defs/editable_dimension", "title": "Lid skirt thickness", "minimum": 1.2, "maximum": 4.0, "x-step": 0.1, "x-ui": {"group": "Lid", "order": 220, "control": "slider"}},
    "lid_fit_clearance": {"$ref": "#/$defs/editable_dimension", "title": "Lid clearance per side", "minimum": 0.05, "maximum": 0.6, "x-step": 0.05, "x-ui": {"group": "Lid", "order": 230, "control": "slider", "warning": "Calibrate for printer and material"}},

    "usb_c_center_x": {"$ref": "#/$defs/locked_coordinate", "title": "USB-C centre X", "x-ui": {"group": "Connector references", "order": 300}},
    "usb_c_opening_width": {"$ref": "#/$defs/advanced_dimension", "title": "USB-C opening width", "minimum": 10.0, "maximum": 18.0, "x-ui": {"group": "Connector openings", "order": 310}},
    "micro_hdmi_0_center_x": {"$ref": "#/$defs/locked_coordinate", "title": "Micro-HDMI 0 centre X", "x-ui": {"group": "Connector references", "order": 320}},
    "micro_hdmi_1_center_x": {"$ref": "#/$defs/locked_coordinate", "title": "Micro-HDMI 1 centre X", "x-ui": {"group": "Connector references", "order": 330}},
    "micro_hdmi_opening_width": {"$ref": "#/$defs/advanced_dimension", "title": "Micro-HDMI opening width", "minimum": 8.0, "maximum": 14.0, "x-ui": {"group": "Connector openings", "order": 340}},
    "audio_center_x": {"$ref": "#/$defs/locked_coordinate", "title": "Audio jack centre X", "x-ui": {"group": "Connector references", "order": 350}},
    "audio_opening_width": {"$ref": "#/$defs/advanced_dimension", "title": "Audio opening width", "minimum": 8.0, "maximum": 16.0, "x-ui": {"group": "Connector openings", "order": 360}},
    "usb_2_center_y": {"$ref": "#/$defs/locked_coordinate", "title": "USB 2 centre Y", "x-ui": {"group": "Connector references", "order": 370}},
    "usb_3_center_y": {"$ref": "#/$defs/locked_coordinate", "title": "USB 3 centre Y", "x-ui": {"group": "Connector references", "order": 380}},
    "usb_opening_width": {"$ref": "#/$defs/advanced_dimension", "title": "USB stack opening width", "minimum": 14.0, "maximum": 22.0, "x-ui": {"group": "Connector openings", "order": 390}},
    "ethernet_center_y": {"$ref": "#/$defs/locked_coordinate", "title": "Ethernet centre Y", "x-ui": {"group": "Connector references", "order": 400}},
    "ethernet_opening_width": {"$ref": "#/$defs/advanced_dimension", "title": "Ethernet opening width", "minimum": 15.0, "maximum": 22.0, "x-ui": {"group": "Connector openings", "order": 410}},
    "microsd_center_y": {"$ref": "#/$defs/locked_coordinate", "title": "MicroSD centre Y", "x-ui": {"group": "Connector references", "order": 420}},
    "microsd_opening_width": {"$ref": "#/$defs/advanced_dimension", "title": "MicroSD opening width", "minimum": 14.0, "maximum": 24.0, "x-ui": {"group": "Connector openings", "order": 430}},

    "gpio_slot_center_x": {"$ref": "#/$defs/advanced_coordinate", "title": "GPIO slot centre X", "x-ui": {"group": "Lid interfaces", "order": 500}},
    "gpio_slot_center_y": {"$ref": "#/$defs/advanced_coordinate", "title": "GPIO slot centre Y", "x-ui": {"group": "Lid interfaces", "order": 510}},
    "gpio_slot_length": {"$ref": "#/$defs/advanced_dimension", "title": "GPIO slot length", "minimum": 45.0, "maximum": 65.0, "x-ui": {"group": "Lid interfaces", "order": 520}},
    "gpio_slot_width": {"$ref": "#/$defs/advanced_dimension", "title": "GPIO slot width", "minimum": 6.0, "maximum": 15.0, "x-ui": {"group": "Lid interfaces", "order": 530}},
    "fan_center_x": {"$ref": "#/$defs/advanced_coordinate", "title": "Fan centre X", "x-ui": {"group": "Lid interfaces", "order": 540}},
    "fan_center_y": {"$ref": "#/$defs/advanced_coordinate", "title": "Fan centre Y", "x-ui": {"group": "Lid interfaces", "order": 550}},
    "fan_hole_pitch": {"$ref": "#/$defs/advanced_dimension", "title": "Fan mounting pitch", "minimum": 20.0, "maximum": 28.0, "x-ui": {"group": "Lid interfaces", "order": 560}},
    "fan_screw_diameter": {"$ref": "#/$defs/advanced_dimension", "title": "Fan screw hole diameter", "minimum": 2.5, "maximum": 4.5, "x-ui": {"group": "Lid interfaces", "order": 570}}
  },
  "$defs": {
    "editable_dimension": {
      "type": "number",
      "x-unit": "mm",
      "x-user-editable": true,
      "x-semantic-change": false
    },
    "advanced_dimension": {
      "type": "number",
      "x-unit": "mm",
      "x-user-editable": true,
      "x-semantic-change": false,
      "x-ui": {"advanced": true}
    },
    "locked_dimension": {
      "type": "number",
      "x-unit": "mm",
      "x-user-editable": false,
      "x-semantic-change": true,
      "x-lock-reason": "Controlled by reference hardware"
    },
    "locked_coordinate": {
      "type": "number",
      "minimum": -100.0,
      "maximum": 100.0,
      "x-unit": "mm",
      "x-user-editable": false,
      "x-semantic-change": true,
      "x-lock-reason": "Controlled by reference hardware"
    },
    "advanced_coordinate": {
      "type": "number",
      "minimum": -100.0,
      "maximum": 100.0,
      "x-unit": "mm",
      "x-user-editable": true,
      "x-semantic-change": false,
      "x-ui": {"advanced": true}
    }
  }
}
