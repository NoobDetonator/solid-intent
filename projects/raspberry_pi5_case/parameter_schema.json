{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.ai-cad/schemas/raspberry_pi5_case.parameters.schema.json",
  "title": "Raspberry Pi 5 enclosure parameters",
  "description": "Validation and parameter-editor metadata for the AI CAD project.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pcb_length",
    "pcb_width",
    "pcb_thickness",
    "mount_pitch_x",
    "mount_pitch_y",
    "mount_edge_offset",
    "mount_hole_diameter",
    "pcb_clearance",
    "wall_thickness",
    "floor_thickness",
    "base_height",
    "outer_corner_radius",
    "standoff_diameter",
    "standoff_height",
    "lid_top_thickness",
    "lid_skirt_depth",
    "lid_skirt_thickness",
    "lid_fit_clearance",
    "usb_c_center_x",
    "usb_c_opening_width",
    "usb_c_z",
    "usb_c_height",
    "micro_hdmi_0_center_x",
    "micro_hdmi_1_center_x",
    "micro_hdmi_opening_width",
    "micro_hdmi_z",
    "micro_hdmi_height",
    "usb_2_center_y",
    "usb_3_center_y",
    "usb_opening_width",
    "usb_z",
    "usb_height",
    "ethernet_center_y",
    "ethernet_opening_width",
    "ethernet_z",
    "ethernet_height",
    "microsd_center_y",
    "microsd_opening_width",
    "microsd_z",
    "microsd_height",
    "gpio_slot_center_x",
    "gpio_slot_center_y",
    "gpio_slot_length",
    "gpio_slot_width",
    "cooler_length",
    "cooler_width",
    "cooler_height",
    "cooler_center_x",
    "cooler_center_y",
    "cooler_fan_clearance",
    "base_vent_length",
    "base_vent_width",
    "lid_vent_length",
    "lid_vent_width"
  ],
  "properties": {
    "pcb_length": {"$ref": "#/$defs/locked_dimension", "title": "PCB length", "minimum": 84.5, "maximum": 85.5, "x-ui": {"group": "Reference PCB", "order": 10}},
    "pcb_width": {"$ref": "#/$defs/locked_dimension", "title": "PCB width", "minimum": 55.5, "maximum": 56.5, "x-ui": {"group": "Reference PCB", "order": 20}},
    "pcb_thickness": {"$ref": "#/$defs/locked_dimension", "title": "Nominal PCB thickness", "minimum": 1.4, "maximum": 2.0, "x-ui": {"group": "Reference PCB", "order": 30}},
    "mount_pitch_x": {"$ref": "#/$defs/locked_dimension", "title": "Mounting pitch X", "minimum": 57.5, "maximum": 58.5, "x-ui": {"group": "Reference PCB", "order": 40}},
    "mount_pitch_y": {"$ref": "#/$defs/locked_dimension", "title": "Mounting pitch Y", "minimum": 48.5, "maximum": 49.5, "x-ui": {"group": "Reference PCB", "order": 50}},
    "mount_edge_offset": {"$ref": "#/$defs/locked_dimension", "title": "Mounting edge offset", "minimum": 3.0, "maximum": 4.0, "x-ui": {"group": "Reference PCB", "order": 60}},
    "mount_hole_diameter": {"$ref": "#/$defs/locked_dimension", "title": "PCB mounting hole diameter", "minimum": 2.5, "maximum": 3.2, "x-ui": {"group": "Reference PCB", "order": 70}},

    "pcb_clearance": {"$ref": "#/$defs/editable_dimension", "title": "PCB edge clearance", "minimum": 0.5, "maximum": 4.0, "x-step": 0.05, "x-ui": {"group": "Base", "order": 100, "control": "number"}},
    "wall_thickness": {"$ref": "#/$defs/editable_dimension", "title": "Wall thickness", "minimum": 1.2, "maximum": 5.0, "x-step": 0.1, "x-ui": {"group": "Base", "order": 110, "control": "slider"}},
    "floor_thickness": {"$ref": "#/$defs/editable_dimension", "title": "Floor thickness", "minimum": 1.2, "maximum": 5.0, "x-step": 0.1, "x-ui": {"group": "Base", "order": 120, "control": "slider"}},
    "base_height": {"$ref": "#/$defs/editable_dimension", "title": "Base height", "minimum": 16.0, "maximum": 45.0, "x-step": 0.1, "x-ui": {"group": "Base", "order": 130, "control": "slider"}},
    "outer_corner_radius": {"$ref": "#/$defs/editable_dimension", "title": "Outer corner radius", "minimum": 1.0, "maximum": 8.0, "x-step": 0.1, "x-ui": {"group": "Base", "order": 140, "control": "slider"}},
    "standoff_diameter": {"$ref": "#/$defs/editable_dimension", "title": "Standoff diameter", "minimum": 4.5, "maximum": 10.0, "x-step": 0.1, "x-ui": {"group": "Mounting", "order": 150, "control": "number"}},
    "standoff_height": {"$ref": "#/$defs/editable_dimension", "title": "Standoff height", "minimum": 2.0, "maximum": 10.0, "x-step": 0.1, "x-ui": {"group": "Mounting", "order": 160, "control": "number"}},

    "lid_top_thickness": {"$ref": "#/$defs/editable_dimension", "title": "Lid top thickness", "minimum": 1.2, "maximum": 5.0, "x-step": 0.1, "x-ui": {"group": "Lid", "order": 200, "control": "slider"}},
    "lid_skirt_depth": {"$ref": "#/$defs/editable_dimension", "title": "Lid skirt depth", "minimum": 1.5, "maximum": 8.0, "x-step": 0.1, "x-ui": {"group": "Lid", "order": 210, "control": "slider"}},
    "lid_skirt_thickness": {"$ref": "#/$defs/editable_dimension", "title": "Lid skirt thickness", "minimum": 1.2, "maximum": 4.0, "x-step": 0.1, "x-ui": {"group": "Lid", "order": 220, "control": "slider"}},
    "lid_fit_clearance": {"$ref": "#/$defs/editable_dimension", "title": "Lid clearance per side", "minimum": 0.05, "maximum": 0.6, "x-step": 0.05, "x-ui": {"group": "Lid", "order": 230, "control": "slider", "warning": "Calibrate for printer and material"}},

    "usb_c_center_x": {"$ref": "#/$defs/locked_dimension", "title": "USB-C centre X", "minimum": -40.0, "maximum": 0.0, "x-ui": {"group": "Connectors", "order": 300}},
    "usb_c_opening_width": {"$ref": "#/$defs/locked_dimension", "title": "USB-C opening width", "minimum": 10.0, "maximum": 16.0, "x-ui": {"group": "Connectors", "order": 301}},
    "usb_c_z": {"$ref": "#/$defs/locked_dimension", "title": "USB-C opening Z", "minimum": 2.0, "maximum": 12.0, "x-ui": {"group": "Connectors", "order": 302}},
    "usb_c_height": {"$ref": "#/$defs/locked_dimension", "title": "USB-C opening height", "minimum": 4.0, "maximum": 12.0, "x-ui": {"group": "Connectors", "order": 303}},
    "micro_hdmi_0_center_x": {"$ref": "#/$defs/locked_dimension", "title": "micro-HDMI 0 centre X", "minimum": -20.0, "maximum": 10.0, "x-ui": {"group": "Connectors", "order": 310}},
    "micro_hdmi_1_center_x": {"$ref": "#/$defs/locked_dimension", "title": "micro-HDMI 1 centre X", "minimum": -10.0, "maximum": 20.0, "x-ui": {"group": "Connectors", "order": 311}},
    "micro_hdmi_opening_width": {"$ref": "#/$defs/locked_dimension", "title": "micro-HDMI opening width", "minimum": 8.0, "maximum": 14.0, "x-ui": {"group": "Connectors", "order": 312}},
    "micro_hdmi_z": {"$ref": "#/$defs/locked_dimension", "title": "micro-HDMI opening Z", "minimum": 2.0, "maximum": 12.0, "x-ui": {"group": "Connectors", "order": 313}},
    "micro_hdmi_height": {"$ref": "#/$defs/locked_dimension", "title": "micro-HDMI opening height", "minimum": 4.0, "maximum": 10.0, "x-ui": {"group": "Connectors", "order": 314}},
    "usb_2_center_y": {"$ref": "#/$defs/locked_dimension", "title": "USB 2 centre Y", "minimum": -28.0, "maximum": 0.0, "x-ui": {"group": "Connectors", "order": 320}},
    "usb_3_center_y": {"$ref": "#/$defs/locked_dimension", "title": "USB 3 centre Y", "minimum": -10.0, "maximum": 10.0, "x-ui": {"group": "Connectors", "order": 321}},
    "usb_opening_width": {"$ref": "#/$defs/locked_dimension", "title": "USB opening width", "minimum": 12.0, "maximum": 20.0, "x-ui": {"group": "Connectors", "order": 322}},
    "usb_z": {"$ref": "#/$defs/locked_dimension", "title": "USB opening Z", "minimum": 2.0, "maximum": 12.0, "x-ui": {"group": "Connectors", "order": 323}},
    "usb_height": {"$ref": "#/$defs/locked_dimension", "title": "USB opening height", "minimum": 10.0, "maximum": 20.0, "x-ui": {"group": "Connectors", "order": 324}},
    "ethernet_center_y": {"$ref": "#/$defs/locked_dimension", "title": "Ethernet centre Y", "minimum": 0.0, "maximum": 28.0, "x-ui": {"group": "Connectors", "order": 330}},
    "ethernet_opening_width": {"$ref": "#/$defs/locked_dimension", "title": "Ethernet opening width", "minimum": 12.0, "maximum": 20.0, "x-ui": {"group": "Connectors", "order": 331}},
    "ethernet_z": {"$ref": "#/$defs/locked_dimension", "title": "Ethernet opening Z", "minimum": 2.0, "maximum": 12.0, "x-ui": {"group": "Connectors", "order": 332}},
    "ethernet_height": {"$ref": "#/$defs/locked_dimension", "title": "Ethernet opening height", "minimum": 10.0, "maximum": 20.0, "x-ui": {"group": "Connectors", "order": 333}},
    "microsd_center_y": {"$ref": "#/$defs/locked_dimension", "title": "microSD centre Y", "minimum": -28.0, "maximum": 0.0, "x-ui": {"group": "Connectors", "order": 340}},
    "microsd_opening_width": {"$ref": "#/$defs/locked_dimension", "title": "microSD opening width", "minimum": 12.0, "maximum": 22.0, "x-ui": {"group": "Connectors", "order": 341}},
    "microsd_z": {"$ref": "#/$defs/locked_dimension", "title": "microSD opening Z", "minimum": 1.0, "maximum": 8.0, "x-ui": {"group": "Connectors", "order": 342}},
    "microsd_height": {"$ref": "#/$defs/locked_dimension", "title": "microSD opening height", "minimum": 3.0, "maximum": 8.0, "x-ui": {"group": "Connectors", "order": 343}},
    "gpio_slot_center_x": {"$ref": "#/$defs/locked_dimension", "title": "GPIO slot centre X", "minimum": -30.0, "maximum": 10.0, "x-ui": {"group": "Connectors", "order": 350}},
    "gpio_slot_center_y": {"$ref": "#/$defs/locked_dimension", "title": "GPIO slot centre Y", "minimum": 15.0, "maximum": 30.0, "x-ui": {"group": "Connectors", "order": 351}},
    "gpio_slot_length": {"$ref": "#/$defs/locked_dimension", "title": "GPIO slot length", "minimum": 40.0, "maximum": 60.0, "x-ui": {"group": "Connectors", "order": 352}},
    "gpio_slot_width": {"$ref": "#/$defs/locked_dimension", "title": "GPIO slot width", "minimum": 6.0, "maximum": 12.0, "x-ui": {"group": "Connectors", "order": 353}},

    "cooler_length": {"$ref": "#/$defs/locked_dimension", "title": "Active Cooler length", "minimum": 60.0, "maximum": 70.0, "x-ui": {"group": "Active Cooler", "order": 360}},
    "cooler_width": {"$ref": "#/$defs/locked_dimension", "title": "Active Cooler width", "minimum": 40.0, "maximum": 50.0, "x-ui": {"group": "Active Cooler", "order": 361}},
    "cooler_height": {"$ref": "#/$defs/locked_dimension", "title": "Active Cooler height", "minimum": 10.0, "maximum": 20.0, "x-ui": {"group": "Active Cooler", "order": 362}},
    "cooler_center_x": {"$ref": "#/$defs/locked_dimension", "title": "Active Cooler centre X", "minimum": -10.0, "maximum": 10.0, "x-ui": {"group": "Active Cooler", "order": 363}},
    "cooler_center_y": {"$ref": "#/$defs/locked_dimension", "title": "Active Cooler centre Y", "minimum": -10.0, "maximum": 10.0, "x-ui": {"group": "Active Cooler", "order": 364}},
    "cooler_fan_clearance": {"$ref": "#/$defs/locked_dimension", "title": "Cooler fan clearance above", "minimum": 0.0, "maximum": 8.0, "x-ui": {"group": "Active Cooler", "order": 365}},

    "base_vent_length": {"$ref": "#/$defs/advanced_dimension", "title": "Base vent slot length", "minimum": 10.0, "maximum": 45.0, "x-ui": {"group": "Ventilation", "order": 400}},
    "base_vent_width": {"$ref": "#/$defs/advanced_dimension", "title": "Base vent slot width", "minimum": 1.5, "maximum": 6.0, "x-ui": {"group": "Ventilation", "order": 410}},
    "lid_vent_length": {"$ref": "#/$defs/advanced_dimension", "title": "Lid vent slot length", "minimum": 10.0, "maximum": 70.0, "x-ui": {"group": "Ventilation", "order": 420}},
    "lid_vent_width": {"$ref": "#/$defs/advanced_dimension", "title": "Lid vent slot width", "minimum": 1.5, "maximum": 6.0, "x-ui": {"group": "Ventilation", "order": 430}}
  },
  "$defs": {
    "editable_dimension": {
      "type": "number",
      "x-unit": "mm",
      "x-user-editable": true,
      "x-semantic-change": false
    },
    "advanced_dimension": {
      "type": "number",
      "x-unit": "mm",
      "x-user-editable": true,
      "x-semantic-change": false,
      "x-ui": {"advanced": true}
    },
    "locked_dimension": {
      "type": "number",
      "x-unit": "mm",
      "x-user-editable": false,
      "x-semantic-change": true,
      "x-lock-reason": "Controlled by reference hardware"
    }
  }
}
