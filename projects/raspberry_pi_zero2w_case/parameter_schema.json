{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.ai-cad/schemas/raspberry_pi_zero2w_case.parameters.schema.json",
  "title": "Raspberry Pi Zero 2 W enclosure parameters",
  "description": "Snap-fit enclosure parameter contract for the Pi Zero 2 W project.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pcb_length", "pcb_width", "pcb_thickness", "pcb_corner_radius",
    "mount_pitch_x", "mount_pitch_y", "mount_edge_offset", "mount_hole_diameter",
    "pcb_clearance", "wall_thickness", "floor_thickness", "base_height", "outer_corner_radius",
    "standoff_diameter", "standoff_height", "locating_pin_diameter",
    "lid_top_thickness", "lid_skirt_depth", "lid_skirt_thickness", "lid_fit_clearance",
    "snap_ridge_height", "snap_ridge_depth", "snap_bead_depth",
    "power_usb_center_x", "data_usb_center_x", "usb_opening_width", "usb_opening_height", "usb_opening_z",
    "hdmi_center_x", "hdmi_opening_width", "hdmi_opening_height", "hdmi_opening_z",
    "sd_opening_width", "sd_opening_height", "sd_opening_z",
    "csi_opening_width", "csi_opening_height", "csi_opening_z",
    "gpio_slot_center_x", "gpio_slot_center_y", "gpio_slot_length", "gpio_slot_width",
    "soc_center_x", "soc_center_y", "vent_hole_diameter", "vent_pitch"
  ],
  "properties": {
    "pcb_length": {"$ref": "#/$defs/locked_dimension", "title": "PCB length", "minimum": 64.5, "maximum": 65.5, "x-ui": {"group": "Reference PCB", "order": 10}},
    "pcb_width": {"$ref": "#/$defs/locked_dimension", "title": "PCB width", "minimum": 29.5, "maximum": 30.5, "x-ui": {"group": "Reference PCB", "order": 20}},
    "pcb_thickness": {"$ref": "#/$defs/locked_dimension", "title": "PCB thickness", "minimum": 1.2, "maximum": 1.8, "x-ui": {"group": "Reference PCB", "order": 30}},
    "pcb_corner_radius": {"$ref": "#/$defs/locked_dimension", "title": "PCB corner radius", "minimum": 2.5, "maximum": 3.5, "x-ui": {"group": "Reference PCB", "order": 40}},
    "mount_pitch_x": {"$ref": "#/$defs/locked_dimension", "title": "Mount pitch X", "minimum": 57.5, "maximum": 58.5, "x-ui": {"group": "Reference PCB", "order": 50}},
    "mount_pitch_y": {"$ref": "#/$defs/locked_dimension", "title": "Mount pitch Y", "minimum": 22.5, "maximum": 23.5, "x-ui": {"group": "Reference PCB", "order": 60}},
    "mount_edge_offset": {"$ref": "#/$defs/locked_dimension", "title": "Mount edge offset", "minimum": 3.0, "maximum": 4.0, "x-ui": {"group": "Reference PCB", "order": 70}},
    "mount_hole_diameter": {"$ref": "#/$defs/locked_dimension", "title": "Mount hole diameter", "minimum": 2.5, "maximum": 3.0, "x-ui": {"group": "Reference PCB", "order": 80}},

    "pcb_clearance": {"$ref": "#/$defs/editable_dimension", "title": "PCB edge clearance", "minimum": 0.4, "maximum": 2.0, "x-step": 0.05, "x-ui": {"group": "Base", "order": 100, "control": "number"}},
    "wall_thickness": {"$ref": "#/$defs/editable_dimension", "title": "Wall thickness", "minimum": 1.4, "maximum": 3.5, "x-step": 0.1, "x-ui": {"group": "Base", "order": 110, "control": "slider"}},
    "floor_thickness": {"$ref": "#/$defs/editable_dimension", "title": "Floor thickness", "minimum": 1.4, "maximum": 3.5, "x-step": 0.1, "x-ui": {"group": "Base", "order": 120, "control": "slider"}},
    "base_height": {"$ref": "#/$defs/editable_dimension", "title": "Base height", "minimum": 8.0, "maximum": 18.0, "x-step": 0.1, "x-ui": {"group": "Base", "order": 130, "control": "slider"}},
    "outer_corner_radius": {"$ref": "#/$defs/editable_dimension", "title": "Outer corner radius", "minimum": 2.0, "maximum": 8.0, "x-step": 0.1, "x-ui": {"group": "Base", "order": 140, "control": "slider"}},
    "standoff_diameter": {"$ref": "#/$defs/editable_dimension", "title": "Standoff diameter", "minimum": 4.0, "maximum": 8.0, "x-step": 0.1, "x-ui": {"group": "Mounting", "order": 150, "control": "number"}},
    "standoff_height": {"$ref": "#/$defs/editable_dimension", "title": "Standoff height", "minimum": 1.5, "maximum": 5.0, "x-step": 0.1, "x-ui": {"group": "Mounting", "order": 160, "control": "number"}},
    "locating_pin_diameter": {"$ref": "#/$defs/editable_dimension", "title": "Locating pin diameter", "minimum": 1.8, "maximum": 2.6, "x-step": 0.05, "x-ui": {"group": "Mounting", "order": 170, "control": "number"}},

    "lid_top_thickness": {"$ref": "#/$defs/editable_dimension", "title": "Lid top thickness", "minimum": 1.4, "maximum": 3.5, "x-step": 0.1, "x-ui": {"group": "Lid", "order": 200, "control": "slider"}},
    "lid_skirt_depth": {"$ref": "#/$defs/editable_dimension", "title": "Lid skirt depth", "minimum": 3.0, "maximum": 8.0, "x-step": 0.1, "x-ui": {"group": "Lid", "order": 210, "control": "slider"}},
    "lid_skirt_thickness": {"$ref": "#/$defs/editable_dimension", "title": "Lid skirt thickness", "minimum": 1.2, "maximum": 3.0, "x-step": 0.1, "x-ui": {"group": "Lid", "order": 220, "control": "slider"}},
    "lid_fit_clearance": {"$ref": "#/$defs/editable_dimension", "title": "Lid clearance per side", "minimum": 0.1, "maximum": 0.5, "x-step": 0.05, "x-ui": {"group": "Lid", "order": 230, "control": "slider", "warning": "Calibrate snap fit for printer/filament"}},

    "snap_ridge_height": {"$ref": "#/$defs/advanced_dimension", "title": "Snap groove height", "minimum": 0.6, "maximum": 1.6, "x-ui": {"group": "Snap fit", "order": 250}},
    "snap_ridge_depth": {"$ref": "#/$defs/advanced_dimension", "title": "Snap groove depth", "minimum": 0.4, "maximum": 1.2, "x-ui": {"group": "Snap fit", "order": 260}},
    "snap_bead_depth": {"$ref": "#/$defs/advanced_dimension", "title": "Snap bead depth", "minimum": 0.4, "maximum": 1.1, "x-ui": {"group": "Snap fit", "order": 270}},

    "power_usb_center_x": {"$ref": "#/$defs/locked_dimension", "title": "Power micro-USB centre X", "minimum": -25.0, "maximum": -15.0, "x-ui": {"group": "Connectors", "order": 300}},
    "data_usb_center_x": {"$ref": "#/$defs/locked_dimension", "title": "Data micro-USB centre X", "minimum": 4.0, "maximum": 14.0, "x-ui": {"group": "Connectors", "order": 310}},
    "usb_opening_width": {"$ref": "#/$defs/locked_dimension", "title": "USB opening width", "minimum": 7.0, "maximum": 12.0, "x-ui": {"group": "Connectors", "order": 320}},
    "usb_opening_height": {"$ref": "#/$defs/locked_dimension", "title": "USB opening height", "minimum": 3.0, "maximum": 6.0, "x-ui": {"group": "Connectors", "order": 321}},
    "usb_opening_z": {"$ref": "#/$defs/locked_dimension", "title": "USB opening Z", "minimum": 2.0, "maximum": 8.0, "x-ui": {"group": "Connectors", "order": 322}},
    "hdmi_center_x": {"$ref": "#/$defs/locked_dimension", "title": "Mini-HDMI centre X", "minimum": 16.0, "maximum": 26.0, "x-ui": {"group": "Connectors", "order": 330}},
    "hdmi_opening_width": {"$ref": "#/$defs/locked_dimension", "title": "Mini-HDMI opening width", "minimum": 6.5, "maximum": 11.0, "x-ui": {"group": "Connectors", "order": 331}},
    "hdmi_opening_height": {"$ref": "#/$defs/locked_dimension", "title": "Mini-HDMI opening height", "minimum": 3.0, "maximum": 6.0, "x-ui": {"group": "Connectors", "order": 332}},
    "hdmi_opening_z": {"$ref": "#/$defs/locked_dimension", "title": "Mini-HDMI opening Z", "minimum": 2.0, "maximum": 8.0, "x-ui": {"group": "Connectors", "order": 333}},
    "sd_opening_width": {"$ref": "#/$defs/locked_dimension", "title": "microSD opening width", "minimum": 10.0, "maximum": 18.0, "x-ui": {"group": "Connectors", "order": 340}},
    "sd_opening_height": {"$ref": "#/$defs/locked_dimension", "title": "microSD opening height", "minimum": 1.5, "maximum": 4.0, "x-ui": {"group": "Connectors", "order": 341}},
    "sd_opening_z": {"$ref": "#/$defs/locked_dimension", "title": "microSD opening Z", "minimum": 2.0, "maximum": 8.0, "x-ui": {"group": "Connectors", "order": 342}},
    "csi_opening_width": {"$ref": "#/$defs/locked_dimension", "title": "CSI opening width", "minimum": 12.0, "maximum": 22.0, "x-ui": {"group": "Connectors", "order": 350}},
    "csi_opening_height": {"$ref": "#/$defs/locked_dimension", "title": "CSI opening height", "minimum": 1.2, "maximum": 4.0, "x-ui": {"group": "Connectors", "order": 351}},
    "csi_opening_z": {"$ref": "#/$defs/locked_dimension", "title": "CSI opening Z", "minimum": 3.0, "maximum": 9.0, "x-ui": {"group": "Connectors", "order": 352}},
    "gpio_slot_center_x": {"$ref": "#/$defs/locked_dimension", "title": "GPIO slot centre X", "minimum": -5.0, "maximum": 5.0, "x-ui": {"group": "Connectors", "order": 360}},
    "gpio_slot_center_y": {"$ref": "#/$defs/locked_dimension", "title": "GPIO slot centre Y", "minimum": 8.0, "maximum": 14.0, "x-ui": {"group": "Connectors", "order": 361}},
    "gpio_slot_length": {"$ref": "#/$defs/locked_dimension", "title": "GPIO slot length", "minimum": 45.0, "maximum": 58.0, "x-ui": {"group": "Connectors", "order": 362}},
    "gpio_slot_width": {"$ref": "#/$defs/locked_dimension", "title": "GPIO slot width", "minimum": 5.0, "maximum": 9.0, "x-ui": {"group": "Connectors", "order": 363}},

    "soc_center_x": {"$ref": "#/$defs/locked_dimension", "title": "SoC centre X", "minimum": -8.0, "maximum": 2.0, "x-ui": {"group": "Ventilation", "order": 400}},
    "soc_center_y": {"$ref": "#/$defs/locked_dimension", "title": "SoC centre Y", "minimum": -5.0, "maximum": 5.0, "x-ui": {"group": "Ventilation", "order": 410}},
    "vent_hole_diameter": {"$ref": "#/$defs/advanced_dimension", "title": "Vent hole diameter", "minimum": 1.6, "maximum": 3.5, "x-ui": {"group": "Ventilation", "order": 420}},
    "vent_pitch": {"$ref": "#/$defs/advanced_dimension", "title": "Vent pitch", "minimum": 3.0, "maximum": 6.0, "x-ui": {"group": "Ventilation", "order": 430}}
  },
  "$defs": {
    "editable_dimension": {
      "type": "number",
      "x-unit": "mm",
      "x-user-editable": true,
      "x-semantic-change": false
    },
    "advanced_dimension": {
      "type": "number",
      "x-unit": "mm",
      "x-user-editable": true,
      "x-semantic-change": false,
      "x-ui": {"advanced": true}
    },
    "locked_dimension": {
      "type": "number",
      "x-unit": "mm",
      "x-user-editable": false,
      "x-semantic-change": true,
      "x-lock-reason": "Controlled by reference hardware"
    }
  }
}
