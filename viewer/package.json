    "express": "^5.2.1",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.1",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
